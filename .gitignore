.ml-cache/
# .ml-cache/ holds local-only working state. Subdirectories include:
#   drafts/         — in-flight intent state pre-seal
#   views/          — rebuilt MainlineView snapshots
#   sessions/       — agent session traces (legacy)
#   webhook-queue/  — outbound webhook envelopes awaiting delivery
#   hooks/          — agent-hooks dispatcher bookkeeping
.mainline/local.toml
/mainline
.claude/
.codex/
.idea/
.vscode/
.env
.env.*
!.env.example
.DS_Store
**/.DS_Store
# rapid PBT failure recordings (per-run, not committed):
internal/engine/testdata/rapid/
.cursor/
.tmp-bin/
dist/
mainline-hub/
hub-export/
# eval run outputs (generated per-run, not committed):
docs/eval-runs/
app-linux-amd64
